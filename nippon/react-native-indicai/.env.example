# ──────────────────────────────────────────────────────────────────────────────
# react-native-indicai — Environment Variables
#
# Copy this file to .env in your React Native app root (NOT inside the SDK).
# These are optional — the SDK uses the production CDN automatically.
# Only set these if you want to point to a custom/staging CDN.
#
# Step 1: Install react-native-config in your app
#   npm install react-native-config
#
# Step 2: Android — add to android/app/build.gradle (top of file):
#   apply from: project(':react-native-config').projectDir.getPath() + "/dotenv.gradle"
#
# Step 3: iOS — add to your Xcode Build Phase "Bundle React Native code and images":
#   export ENVFILE=.env
#
# Step 4: Copy this file to your app root as .env and set the values below.
#   The SDK reads them automatically on import — no extra code needed.
# ──────────────────────────────────────────────────────────────────────────────

# Manifest JSON URL — the SDK fetches this first to discover model file names & SHA256.
# Leave blank (or remove this line) to use the built-in production CDN.
INDICAI_MANIFEST_URL=

# S3 base URL — individual model .zip files are downloaded from here.
# Leave blank (or remove this line) to use the built-in production CDN.
INDICAI_S3_BASE_URL=
