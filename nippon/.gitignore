*.xcworkspace
*.xcuserdata
Pods/
ios/Pods/
DerivedData/
*.ipa
*.dSYM.zip
*.dSYM/

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Secrets (never commit) ───────────────────────────────────────────────────
