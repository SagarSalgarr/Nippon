# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.venv/
venv/
env/
*.so

# ── Pipeline: models, dist, eval, cache (multi-GB, never commit) ──────────────
pipeline/models/
pipeline/dist/
pipeline/eval_results/
pipeline/sdk_cache/
pipeline/*.wav
pipeline/*.data
pipeline/*.onnx
pipeline/upload_log.txt
pipeline/intent_config.json

# ── Junk / scratch files ──────────────────────────────────────────────────────
*.bak
*.tmp
*.xlsx
*.xls

# ── Node / React Native ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log
.yarn/
package-lock.json
yarn.lock

# ── Android ───────────────────────────────────────────────────────────────────
*.apk
*.aab
*.dex
*.class
*.jar
*.aar
build/
.gradle/
react-native-indicai/android/build/
react-native-indicai/android/.gradle/
react-native-indicai/android/libs/*.aar
IndicAIDemo/android/app/build/
IndicAIDemo/android/.gradle/
local.properties

# ── iOS / Xcode ───────────────────────────────────────────────────────────────
