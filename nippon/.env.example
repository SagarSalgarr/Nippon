# ──────────────────────────────────────────────────────────────────────────────
# IndicAI Demo App — Environment Variables
#
# Copy this file to .env in the same folder (nippon/) and fill in values.
# Never commit the actual .env file to git.
#
# These are read by react-native-config and passed to the IndicAI SDK.
# ──────────────────────────────────────────────────────────────────────────────

# CDN — where the SDK downloads model files from.
# Leave blank to use the default production CDN (recommended).
# Only set these if you are hosting models on your own S3/CDN.
INDICAI_MANIFEST_URL=
INDICAI_S3_BASE_URL=
